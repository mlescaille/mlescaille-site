---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import { isPublished } from '../../content.config';

export async function getStaticPaths() {
  const posts = await getCollection('work', entry => isPublished(entry) && !entry.data.external && entry.data.kind === 'poem');
  return posts.map(post => ({ params: { id: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// "More like this": nearest published poems.
const siblings = (await getCollection('work', entry =>
  isPublished(entry) && entry.id !== post.id && entry.data.kind === 'poem'
)).sort((a, b) =>
  Math.abs(a.data.date.valueOf() - post.data.date.valueOf()) -
  Math.abs(b.data.date.valueOf() - post.data.date.valueOf())
).slice(0, 2);

const backLink = { href: '/poetry', label: 'All poetry' };
---
<Base title={`${post.data.title} — Mari Lescaille`} description={post.data.note}>
<style>
  .meta{font-family:var(--mono);font-size:12.5px;color:var(--purple);padding:44px 0 8px}
  h1{font-size:clamp(28px,5.4vw,40px);font-weight:500;line-height:1.15;letter-spacing:-.01em}
  .date{font-family:var(--mono);font-size:13px;color:var(--muted);margin-top:10px}
  article{margin-top:34px;font-size:18.5px}
  article :global(p){margin:0 0 18px}
  article :global(h2){font-size:24px;font-weight:600;margin:36px 0 12px}
  article :global(h3){font-size:19px;font-weight:600;margin:28px 0 10px}
  article :global(h4){font-size:18.5px;font-weight:600;margin:26px 0 10px}
  article :global(blockquote){border-left:3px solid var(--purple);padding:2px 0 2px 16px;color:var(--muted);font-style:italic;margin:0 0 18px}
  article :global(code){font-family:var(--mono);font-size:.85em;background:var(--purple-soft);border-radius:4px;padding:1px 5px}
  article :global(pre){background:var(--bg-raise);border:1px solid var(--line);border-radius:8px;padding:16px;overflow-x:auto;margin:0 0 18px}
  article :global(pre code){background:none;padding:0;font-size:14px}
  article :global(ul),article :global(ol){margin:0 0 18px 22px}
  article :global(li){margin-bottom:6px}
  article :global(hr){border:none;border-top:1px solid var(--line);margin:32px 0}
  article.poem :global(p){margin:0 0 4px;padding-left:1.1em;text-indent:-1.1em}
  article :global(img){max-width:100%;height:auto;border-radius:8px;display:block;margin:0 auto}

  .after{margin-top:56px;border-top:1px solid var(--line);padding-top:22px}
  .after .sec-label{margin-bottom:14px}
  .after li{list-style:none;padding:10px 0;display:grid;grid-template-columns:1fr auto;gap:4px 16px;align-items:baseline}
  .after .title{font-size:17px;font-weight:500}
  .after .title a{color:var(--ink);text-decoration:none}
  .after .title a:hover{color:var(--purple);text-decoration:underline}
  .after .note{grid-column:1;color:var(--muted);font-size:15px;line-height:1.5}
  .after .year{font-family:var(--mono);font-size:12px;color:var(--muted)}
  .after .paths{margin-top:18px;font-family:var(--mono);font-size:13.5px;display:flex;gap:18px;flex-wrap:wrap}
</style>
<div class="meta">{post.data.kind}</div>
<h1>{post.data.title}</h1>
<div class="date">{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</div>
<article class="poem"><Content /></article>

<aside class="after" aria-labelledby="more-label">
  {siblings.length > 0 && (
    <>
      <div class="sec-label" id="more-label"><span class="es">más</span> More like this</div>
      <ul>
        {siblings.map(s => (
          <li>
            <span class="title"><a href={`/poetry/${s.id}/`}>{s.data.title}</a></span>
            <span class="year">{s.data.date.getFullYear()}</span>
            {s.data.note && <span class="note">{s.data.note}</span>}
          </li>
        ))}
      </ul>
    </>
  )}
  <p class="paths">
    <a href={backLink.href}>← {backLink.label}</a>
    <a href="/rss.xml">Follow via RSS</a>
    <a href="/#letter-label">Subscribe</a>
  </p>
</aside>
</Base>
