---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('work', ({ data }) => !data.draft && data.kind !== 'poem'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<Base title="Writing — Mari Lescaille">
<style>
  h1{font-size:clamp(28px,5vw,38px);font-weight:500;padding:44px 0 6px}
  .work{margin-top:20px}
  .work li{list-style:none;padding:17px 0;border-bottom:1px solid var(--line);display:grid;grid-template-columns:108px 1fr auto;gap:6px 16px;align-items:baseline}
  .work li:last-child{border-bottom:none}
  .work .kind{font-family:var(--mono);font-size:11.5px;color:var(--purple);background:var(--purple-soft);border-radius:12px;padding:2px 10px;justify-self:start}
  .work .title{font-size:18.5px;font-weight:500}
  .work .title a{color:var(--ink);text-decoration:none}
  .work .title a:hover{color:var(--purple);text-decoration:underline}
  .work .note{grid-column:2;color:var(--muted);font-size:15.5px;line-height:1.5}
  .work .year{font-family:var(--mono);font-size:12px;color:var(--muted)}
  @media (max-width:560px){
    .work li{grid-template-columns:1fr auto}
    .work .kind,.work .note{grid-column:1 / -1}
  }
</style>
<h1>Writing</h1>
<ul class="work">
  {posts.map(entry => (
    <li>
      <span class="kind">{entry.data.kind}</span>
      <span class="title">
        <a href={entry.data.external ?? `/writing/${entry.id}/`} target={entry.data.external && '_blank'} rel={entry.data.external && 'noopener noreferrer'}>
          {entry.data.title}{entry.data.external && <span class="external-arrow" aria-hidden="true">↗</span>}
        </a>
      </span>
      <span class="year">{entry.data.date.getFullYear()}</span>
      {entry.data.note && <span class="note">{entry.data.note}</span>}
    </li>
  ))}
</ul>
</Base>
