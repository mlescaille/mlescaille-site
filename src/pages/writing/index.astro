---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { isPublished } from '../../content.config';

const SHELVES = [
  { id: 'systems', label: 'Systems & craft', es: 'sistemas', desc: 'Reading, debugging, and building software systems.' },
  { id: 'tech', label: 'Working in tech', es: 'oficio', desc: 'Careers, teams, and the humans in the machine.' },
  { id: 'essays', label: 'Essays', es: 'ensayos', desc: 'Personal essays, culture, and the writing life.' },
  { id: 'archive', label: 'Field notes & archive', es: 'archivo', desc: 'Dated tutorials and short notes, kept as receipts.' },
];

const WRITTEN_KINDS = ['essay', 'code · poems', 'convention', 'explorable'];
const posts = (await getCollection('work', entry => isPublished(entry) && WRITTEN_KINDS.includes(entry.data.kind)))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const shelves = SHELVES
  .map(shelf => ({ ...shelf, entries: posts.filter(p => p.data.shelf === shelf.id) }))
  .filter(shelf => shelf.entries.length > 0);
---
<Base title="Writing — Mari Lescaille">
<style>
  h1{font-size:clamp(28px,5vw,38px);font-weight:500;padding:44px 0 6px}
  section{padding:40px 0 0}
  section:first-of-type{padding-top:24px}
  .shelf-desc{color:var(--muted);font-size:15.5px;margin-top:8px}
  .work{margin-top:10px}
  .work li{list-style:none;padding:15px 0;border-bottom:1px solid var(--line);display:grid;grid-template-columns:1fr auto;gap:4px 16px;align-items:baseline}
  .work li:last-child{border-bottom:none}
  .work .title{font-size:18.5px;font-weight:500}
  .work .title a{color:var(--ink);text-decoration:none}
  .work .title a:hover{color:var(--purple);text-decoration:underline}
  .work .note{grid-column:1;color:var(--muted);font-size:15.5px;line-height:1.5}
  .work .year{font-family:var(--mono);font-size:12px;color:var(--muted)}
</style>
<h1>Writing</h1>
{shelves.map(shelf => (
  <section aria-labelledby={`shelf-${shelf.id}`}>
    <div class="sec-label" id={`shelf-${shelf.id}`}><span class="es">{shelf.es}</span> {shelf.label}</div>
    <p class="shelf-desc">{shelf.desc}</p>
    <ul class="work">
      {shelf.entries.map(entry => (
        <li>
          <span class="title">
            <a href={entry.data.external ?? `/writing/${entry.id}/`} target={entry.data.external && '_blank'} rel={entry.data.external && 'noopener noreferrer'}>
              {entry.data.title}{entry.data.external && <span class="external-arrow" aria-hidden="true">↗</span>}
            </a>
          </span>
          <span class="year">{entry.data.date.getFullYear()}</span>
          {entry.data.note && <span class="note">{entry.data.note}</span>}
        </li>
      ))}
    </ul>
  </section>
))}
</Base>
