---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { isPublished } from '../content.config';

// Hand-picked front door, in reading order — edit this list to change it.
const START_HERE = [
  'navigating-large-codebases',
  'chop-wood-carry-water',
  'debugging-map-territory',
  'my-grandma-braid-my-hair',
  'we-the-drama-cultures',
  'introducing-codems',
];

const all = await getCollection('work', isPublished);
const startHere = START_HERE
  .map(id => all.find(entry => entry.id === id))
  .filter(Boolean);

// Chronological view, separate from the curated picks above.
const LATEST_KINDS = ['essay', 'code · poems', 'poem', 'convention', 'explorable'];
const latest = all
  .filter(entry => LATEST_KINDS.includes(entry.data.kind) && !START_HERE.includes(entry.id))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const ROOMS = { systems: 'systems & craft', tech: 'working in tech', essays: 'essay', archive: 'archive' };
function roomFor(entry) {
  if (entry.data.kind === 'code · poems') return 'codems';
  if (entry.data.kind === 'poem') return 'poem';
  return ROOMS[entry.data.shelf] ?? entry.data.kind;
}

const latestWithRoom = latest.map(entry => ({ entry, room: roomFor(entry) }));
const startHereWithRoom = startHere.map(entry => ({ entry, room: roomFor(entry) }));

function linkFor(entry) {
  return entry.data.external ?? `/writing/${entry.id}/`;
}
---
<Base>
<style>
  .intro{padding:44px 0 0;font-size:19px}
  .intro p+p{margin-top:18px}
  .intro .tech{font-family:var(--mono);font-size:.86em;background:var(--purple-soft);border-radius:4px;padding:1px 6px}
  .intro .es{font-style:italic}
  section{padding:56px 0 0}
  /* One shared row component for both lists — the same bordered
     title/note/year row used on /writing and /poetry. Only the item
     selection and the section header differ; the row itself never does. */
  .homelist{margin-top:14px}
  .homelist li{list-style:none;padding:15px 0;border-bottom:1px solid var(--line);display:grid;grid-template-columns:1fr auto;gap:4px 16px;align-items:baseline}
  .homelist li:last-child{border-bottom:none}
  .homelist .title{font-size:18.5px;font-weight:500}
  .homelist .title a{color:var(--ink);text-decoration:none}
  .homelist .title a:hover{color:var(--purple);text-decoration:underline}
  .homelist .room{font-family:var(--mono);font-size:11px;color:var(--purple);background:var(--purple-soft);border-radius:999px;padding:2px 9px;margin-left:8px;white-space:nowrap}
  .homelist .note{grid-column:1;color:var(--muted);font-size:15.5px;line-height:1.5}
  .homelist .year{font-family:var(--mono);font-size:12px;color:var(--muted)}
  .more{margin-top:20px;font-family:var(--mono);font-size:13.5px}
  .letter{margin-top:20px}
  .letter p{max-width:520px}
  .letter form{margin-top:16px;display:flex;gap:10px;flex-wrap:wrap}
  .letter input[type=email]{font-family:var(--mono);font-size:14px;padding:11px 14px;border:1px solid var(--line);border-radius:6px;background:var(--bg-raise);color:var(--ink);flex:1;min-width:220px}
  .letter button{font-family:var(--mono);font-size:14px;font-weight:500;padding:11px 20px;border:1px solid var(--purple);border-radius:6px;background:var(--purple);color:var(--paper);cursor:pointer}
  .letter button:hover{background:var(--purple-strong);border-color:var(--purple-strong)}
</style>

<div class="intro">
  <p>I'm Mari. I'm a staff software engineer at Netflix, where I work on consumer identity — the systems that know which device is yours, which session to end, which of two hundred million accounts just signed in. I've been writing software for fifteen years and poems for longer, in two languages <span class="es">(a veces en las dos a la vez)</span>.</p>
  <p>I learn by building, so most of what lives here is something you can read, run, or play with: essays on <span class="tech">debugging</span> and <span class="tech">distributed&nbsp;systems</span>, poems, stories, the occasional talk. The engineering and the poetry come from the same hands, and I stopped keeping them in separate rooms.</p>
  <p>Cuba → Uruguay → United States. California, these days.</p>
</div>

<section aria-labelledby="start-label">
  <div class="sec-label" id="start-label"><span class="es">empieza aquí</span> start here</div>
  <ul class="homelist">
    {startHereWithRoom.map(({ entry, room }) => (
      <li>
        <span class="title">
          <a href={linkFor(entry)} target={entry.data.external && '_blank'} rel={entry.data.external && 'noopener noreferrer'}>
            {entry.data.title}{entry.data.external && <span class="external-arrow" aria-hidden="true">↗</span>}
          </a>
          <span class="room">{room}</span>
        </span>
        <span class="year">{entry.data.date.getFullYear()}</span>
        {entry.data.note && <span class="note">{entry.data.note}</span>}
      </li>
    ))}
  </ul>
  <p class="more"><a href="/writing">All writing →</a> · <a href="/poetry">Poetry →</a></p>
</section>

<section aria-labelledby="latest-label">
  <div class="sec-label" id="latest-label"><span class="es">recién publicado</span> latest</div>
  <ul class="homelist">
    {latestWithRoom.map(({ entry, room }) => (
      <li>
        <span class="title">
          <a href={linkFor(entry)}>{entry.data.title}</a>
          <span class="room">{room}</span>
        </span>
        <span class="year">{entry.data.date.getFullYear()}</span>
        {entry.data.note && <span class="note">{entry.data.note}</span>}
      </li>
    ))}
  </ul>
</section>

<section aria-labelledby="letter-label">
  <div class="sec-label" id="letter-label"><span class="es">cartas</span> letters</div>
  <div class="letter">
    <p>If you like what you find here, I hope you'll allow me into the sacred space that is your email, and share this journey with me.</p>
    <!-- NEWSLETTER: point action at your provider. Buttondown example:
         action="https://buttondown.com/api/emails/embed-subscribe/mlescaille" -->
    <form action="#" method="post">
      <input type="email" name="email" placeholder="you@example.com" aria-label="Email address" required>
      <button type="submit">I'm in</button>
    </form>
  </div>
</section>
</Base>
