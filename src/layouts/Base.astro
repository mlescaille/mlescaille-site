---
interface Props {
  title?: string;
  description?: string;
  markdownUrl?: string;
  pageStructuredData?: Record<string, unknown>;
}
const {
  title = 'Mari Lescaille',
  description = 'Staff software engineer and poet. Essays, explorable systems, poems in two languages.',
  markdownUrl,
  pageStructuredData,
} = Astro.props;

const path = Astro.url.pathname;
const nav = [
  { href: '/writing', label: 'Writing' },
  { href: '/poetry', label: 'Poetry' },
  { href: '/speaking/', label: 'Speaking & Media' },
  { href: '/about', label: 'About' },
];
const isCurrent = (href: string) => {
  const clean = href.replace(/\/$/, '');
  return path === clean || path === clean + '/' || path.startsWith(clean + '/');
};

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const discoveryURL = new URL('/llms.txt', Astro.site);
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${Astro.site}#website`,
      url: Astro.site,
      name: 'Mari Lescaille',
      description: 'Essays on software systems, engineering practice, and the writing life — plus poetry in English and Spanish.',
      author: { '@id': `${Astro.site}#person` },
      inLanguage: ['en', 'es'],
    },
    {
      '@type': 'Person',
      '@id': `${Astro.site}#person`,
      name: 'Marisniulkis Lescaille',
      alternateName: 'Mari Lescaille',
      url: Astro.site,
      jobTitle: 'Staff Software Engineer',
      sameAs: [
        'https://github.com/mlescaille',
        'https://www.linkedin.com/in/mlescaille',
        'https://mlescaille.medium.com/',
      ],
    },
    ...(pageStructuredData ? [pageStructuredData] : []),
  ],
};
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{title}</title>
<meta name="description" content={description}>
<link rel="canonical" href={canonicalURL}>
<meta property="og:type" content="website">
<meta property="og:title" content={title}>
<meta property="og:description" content={description}>
<meta property="og:url" content={canonicalURL}>
<meta property="og:site_name" content="Mari Lescaille">
<meta name="twitter:card" content="summary">
<meta name="twitter:title" content={title}>
<meta name="twitter:description" content={description}>
<link rel="icon" type="image/png" sizes="512x512" href="/favicon.png">
<link rel="apple-touch-icon" href="/favicon.png">
<link rel="alternate" type="application/rss+xml" title="Mari Lescaille" href="/rss.xml">
<link rel="alternate" type="text/plain" title="Guide for language models" href={discoveryURL}>
{markdownUrl && <link rel="alternate" type="text/markdown" title="Markdown version" href={markdownUrl}>}
<script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Literata:ital,opsz,wght@0,7..72,400;0,7..72,500;0,7..72,600;1,7..72,400;1,7..72,500&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

<!-- ANALYTICS: create a free account at goatcounter.com (site code: mlescaille),
     then uncomment. No cookies, no banner needed, public or private dashboard
     at https://mlescaille.goatcounter.com -->
<!-- <script data-goatcounter="https://mlescaille.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script> -->

<style is:global>
  /* Palette from the VenusIT posters, Havana 2013 */
  :root{
    color-scheme:light;
    --paper:#FAF7FD;
    --ink:#2C1244;
    --muted:#5D4579;
    --line:#E3D6F2;
    --purple:#5B2D86;
    --purple-strong:#8A5BBF;
    --purple-soft:#F0E7FA;
    --pink:#D6317F;
    --bg-raise:#FFFFFF;
    --shadow:0 2px 12px rgba(60,27,87,.08);
    /* aliases */
    --bg:var(--paper);
    --ink-soft:var(--muted);
    --lavender:var(--purple-strong);
    --chip-bg:var(--purple-soft);
    --serif:"Literata",Georgia,serif;
    --mono:"JetBrains Mono",ui-monospace,monospace;
  }
  @media (prefers-color-scheme: dark){
    :root{
      color-scheme:dark;
      --paper:#1D0B33;
      --ink:#EFE5FB;
      --muted:#B79ED6;
      --line:#3E2360;
      --purple:#C9A9E8;
      --purple-strong:#A87ED4;
      --purple-soft:#341A55;
      --pink:#F06BAC;
      --bg-raise:#2A1347;
      --shadow:0 2px 14px rgba(0,0,0,.35);
    }
  }
  *{margin:0;padding:0;box-sizing:border-box}
  body{background:var(--paper);color:var(--ink);font-family:var(--serif);font-size:18px;line-height:1.65;-webkit-font-smoothing:antialiased;border-top:4px solid var(--purple)}
  ::selection{background:var(--purple);color:var(--paper)}
  a{color:var(--purple);text-decoration-thickness:1px;text-underline-offset:3px}
  a:hover{text-decoration-thickness:2px}
  a:focus-visible,button:focus-visible,input:focus-visible{outline:2px solid var(--purple);outline-offset:3px;border-radius:2px}
  .wrap{max-width:660px;margin:0 auto;padding:0 22px}

  header.site{padding:44px 0 0}
  .site-identity{display:flex;align-items:center;gap:17px}
  .brand-symbol{display:block;width:72px;flex:0 0 72px;line-height:0}
  .brand-symbol img{display:block;width:100%;height:auto;filter:drop-shadow(0 5px 12px rgba(91,45,134,.1))}
  .identity-copy{min-width:0}
  .masthead{font-weight:500;font-size:clamp(26px,5vw,34px);line-height:1.1;letter-spacing:-.01em}
  .masthead a{color:var(--ink);text-decoration:underline;text-decoration-color:var(--line);text-decoration-thickness:1.5px;text-underline-offset:5px;transition:color .15s ease,text-decoration-color .15s ease}
  .masthead .last{font-style:italic;font-weight:400;color:var(--purple);transition:color .15s ease}
  .masthead a:hover{color:var(--purple);text-decoration-color:var(--purple);text-decoration-thickness:2px}
  .masthead a:hover .last{color:var(--purple-strong)}
  nav.site{margin-top:14px;font-family:var(--mono);font-size:13.5px;display:flex;gap:8px 22px;flex-wrap:wrap}
  nav.site a{color:var(--ink);text-decoration:none}
  nav.site a:hover{color:var(--purple-strong);text-decoration:underline;text-decoration-thickness:2px}
  nav.site a[aria-current="page"]{color:var(--pink)}
  @media (max-width:480px){
    .site-identity{gap:13px}
    .brand-symbol{width:58px;flex-basis:58px}
    nav.site{gap:7px 14px;font-size:12.5px}
  }

  main{padding-bottom:24px}

  .sec-label{font-family:var(--mono);font-size:12.5px;letter-spacing:.06em;color:var(--purple);display:flex;align-items:baseline;gap:12px}
  .sec-label::after{content:"";flex:1;border-top:2px solid var(--purple-soft)}
  .sec-label .es{color:var(--pink);font-weight:500}

  footer.site{margin-top:72px;border-top:1px solid var(--line);padding:24px 0 56px;font-family:var(--mono);font-size:13px;color:var(--muted)}
  footer.site .row{display:flex;justify-content:space-between;gap:10px 20px;flex-wrap:wrap}
  footer.site a{color:var(--muted);text-decoration:none}
  footer.site a:hover{color:var(--purple);text-decoration:underline}
  footer.site .links{display:flex;gap:16px;flex-wrap:wrap}
  a .external-arrow{font-size:.78em;margin-left:.2em}
</style>
</head>
<body>
<div class="wrap">
  <header class="site">
    <div class="site-identity">
      <a class="brand-symbol" href="/" aria-label="Mari Lescaille home">
        <img src="/brand-mark.webp" width="640" height="640" alt="">
      </a>
      <div class="identity-copy">
        <div class="masthead"><a href="/">Mari <span class="last">Lescaille</span></a></div>
        <!-- External link convention: target="_blank" rel="noopener noreferrer" + <span class="external-arrow" aria-hidden="true">↗</span> -->
        <nav class="site" aria-label="Site">
          {nav.map(item => (
            <a href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined}>{item.label}</a>
          ))}
        </nav>
      </div>
    </div>
  </header>
  <main>
    <slot />
  </main>
</div>
<footer class="site">
  <div class="wrap row">
    <span>Mari Lescaille</span>
    <span class="links">
      <a href="https://mlescaille.medium.com/" target="_blank" rel="noopener noreferrer">Medium<span class="external-arrow" aria-hidden="true">↗</span></a>
      <a href="https://github.com/mlescaille" target="_blank" rel="noopener noreferrer">GitHub<span class="external-arrow" aria-hidden="true">↗</span></a>
      <a href="https://www.linkedin.com/in/mlescaille" target="_blank" rel="noopener noreferrer">LinkedIn<span class="external-arrow" aria-hidden="true">↗</span></a>
      <a href="https://www.youtube.com/@marisniulkislescaille9673" target="_blank" rel="noopener noreferrer">YouTube<span class="external-arrow" aria-hidden="true">↗</span></a>
      <a href="/rss.xml">RSS</a>
    </span>
  </div>
</footer></body>
</html>
